{
  "name": "std",
  "version": "1.0.0",
  "description": "A fully responsive, modern vacation rental website built with vanilla JavaScript, HTML, and CSS. Features include property listings, detailed property pages, interactive calendar with availability tracking, dynamic pricing calculator with hidden seasonal adjustments, image gallery with lightbox, and guest reviews system.",
  "main": "app.js",
  "scripts": {
    "sync-calendars": "node scripts/sync-calendars.cjs",
    "generate-sitemap": "node scripts/generate-sitemap.cjs",
    "generate-listing-schema": "node scripts/generate-listing-schema.cjs",
    "cache-bust": "node scripts/cache-bust.cjs",
    "serve": "npx --yes serve -l 3000 .",
    "lint:js": "node scripts/lint-js.cjs",
    "lint:html": "npx --yes htmlhint@1 \"**/*.html\" --ignore \"node_modules/**\"",
    "lint": "npm run lint:js && npm run lint:html",
    "test": "npm run lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SimoneKhalilFL/Serenity.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/SimoneKhalilFL/Serenity/issues"
  },
  "homepage": "https://github.com/SimoneKhalilFL/Serenity#readme",
  "dependencies": {
    "node-ical": "^0.26.0"
  },
  "devDependencies": {
    "sharp": "^0.34.5"
  }
}
